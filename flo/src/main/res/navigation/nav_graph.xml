<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation_main"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/archiveFragment"
        android:name="com.example.flo.ArchiveFragment"
        android:label="fragment_archive"
        tools:layout="@layout/fragment_archive" />
    <fragment
        android:id="@+id/albumFragment"
        android:name="com.example.flo.AlbumFragment"
        android:label="fragment_album"
        tools:layout="@layout/fragment_album">
        <argument
            android:name="track"
            app:argType="com.example.flo.TrackModel"
            app:nullable="true"/>
    </fragment>
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.flo.home.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_homeFragment_to_albumFragment"
            app:destination="@id/albumFragment" />
    </fragment>
    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.flo.SearchFragment"
        android:label="fragment_search"
        tools:layout="@layout/fragment_search" />
</navigation>