<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/tvAlbumListTrackNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="01"
        android:textSize="16sp"
        android:textColor="@color/gray_700"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvAlbumListTrackTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        tools:text="노래 이름"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="@id/tvAlbumListTrackNumber"
        app:layout_constraintBottom_toBottomOf="@id/tvAlbumListTrackNumber"
        app:layout_constraintStart_toEndOf="@id/tvAlbumListTrackNumber"/>

    <TextView
        android:id="@+id/tvAlbumListTrackArtist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/gray_500"
        app:layout_constraintStart_toStartOf="@id/tvAlbumListTrackTitle"
        app:layout_constraintTop_toBottomOf="@id/tvAlbumListTrackTitle"
        tools:text="가수 이름" />

    <ImageView
        android:id="@+id/ivAlbumListTrackOption"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_option"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ImageView
        android:id="@+id/ivAlbumListTrackPlay"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_play_filled"
        android:layout_marginEnd="12dp"
        app:layout_constraintEnd_toStartOf="@id/ivAlbumListTrackOption"
        app:layout_constraintTop_toTopOf="@id/ivAlbumListTrackOption"
        app:layout_constraintBottom_toBottomOf="@id/ivAlbumListTrackOption"/>

</androidx.constraintlayout.widget.ConstraintLayout>