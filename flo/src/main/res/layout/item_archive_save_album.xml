<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginBottom="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/ivArchiveSaveAlbumThumbnail"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/img_no_track" />

    <TextView
        android:id="@+id/tvArchiveSaveAlbumTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        tools:text="앨범 이름"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:textSize="18sp"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintTop_toTopOf="@id/ivArchiveSaveAlbumThumbnail"
        app:layout_constraintBottom_toTopOf="@id/tvArchiveSaveAlbumArtistName"
        app:layout_constraintStart_toEndOf="@id/ivArchiveSaveAlbumThumbnail"/>

    <TextView
        android:id="@+id/tvArchiveSaveAlbumArtistName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        tools:text="가수 이름"
        android:textColor="@color/black"
        app:layout_constraintTop_toBottomOf="@id/tvArchiveSaveAlbumTitle"
        app:layout_constraintStart_toStartOf="@id/tvArchiveSaveAlbumTitle"
        app:layout_constraintBottom_toTopOf="@id/llArchiveSaveAlbumDetail"/>

    <LinearLayout
        android:id="@+id/llArchiveSaveAlbumDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/tvArchiveSaveAlbumArtistName"
        app:layout_constraintStart_toStartOf="@id/tvArchiveSaveAlbumArtistName"
        app:layout_constraintBottom_toBottomOf="@id/ivArchiveSaveAlbumThumbnail">

        <TextView
            android:id="@+id/tvArchiveSaveAlbumReleaseDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            tools:text="2025.05.15" />

        <View
            android:layout_width="1dp"
            android:layout_height="12dp"
            android:layout_marginEnd="4dp"
            android:background="@color/gray_200"/>

        <TextView
            android:id="@+id/tvArchiveSaveAlbumFormat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            tools:text="정규"/>

        <View
            android:layout_width="1dp"
            android:layout_height="12dp"
            android:layout_marginEnd="4dp"
            android:background="@color/gray_200" />

        <TextView
            android:id="@+id/tvArchiveSaveAlbumGenre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="JPOP" />

    </LinearLayout>

    <ImageView
        android:id="@+id/ivArchiveSaveAlbumPlay"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_play_filled"
        android:layout_marginEnd="12dp"
        app:layout_constraintEnd_toStartOf="@id/ivArchiveSaveAlbumOption"
        app:layout_constraintTop_toTopOf="@id/ivArchiveSaveAlbumOption"
        app:layout_constraintBottom_toBottomOf="@id/ivArchiveSaveAlbumOption"/>

    <ImageView
        android:id="@+id/ivArchiveSaveAlbumOption"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_option"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>