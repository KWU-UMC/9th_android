<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".home.HomeFragment">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager2MusicBanner"
        android:layout_width="0dp"
        android:layout_height="280dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
    </androidx.viewpager2.widget.ViewPager2>

    <me.relex.circleindicator.CircleIndicator3
        android:id="@+id/circleIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/viewPager2MusicBanner"
        app:selectedDotColor="@color/secondary_color" />

    <TextView
        android:id="@+id/tvTodayReleasedMusicTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="20dp"
        android:text="오늘 발매된 앨범"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewPager2MusicBanner" />

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="4dp"
        android:src="@drawable/ic_arrow_right"
        app:layout_constraintBottom_toBottomOf="@id/tvTodayReleasedMusicTitle"
        app:layout_constraintStart_toEndOf="@id/tvTodayReleasedMusicTitle"
        app:layout_constraintTop_toTopOf="@id/tvTodayReleasedMusicTitle" />

    <TextView
        android:id="@+id/tvTodayReleasedMusicForeign"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:text="해외"
        app:layout_constraintBottom_toBottomOf="@id/tvTodayReleasedMusicTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvTodayReleasedMusicTitle" />

    <TextView
        android:id="@+id/tvTodayReleasedMusicDomestic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:text="국내"
        app:layout_constraintBottom_toBottomOf="@id/tvTodayReleasedMusicForeign"
        app:layout_constraintEnd_toStartOf="@id/tvTodayReleasedMusicForeign"
        app:layout_constraintTop_toTopOf="@id/tvTodayReleasedMusicForeign" />

    <TextView
        android:id="@+id/tvTodayReleasedMusicGeneral"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:text="종합"
        android:textColor="@color/secondary_color"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/tvTodayReleasedMusicDomestic"
        app:layout_constraintEnd_toStartOf="@id/tvTodayReleasedMusicDomestic"
        app:layout_constraintTop_toTopOf="@id/tvTodayReleasedMusicDomestic" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerviewHome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        tools:layout_height="140dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="20dp"
        tools:listitem="@layout/item_home_today_released_album"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTodayReleasedMusicTitle"/>

</androidx.constraintlayout.widget.ConstraintLayout>