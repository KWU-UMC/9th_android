<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="16dp"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/ivTodayReleasedTrack"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:scaleType="centerCrop"
        tools:src="@drawable/img_album_today_released_1" />

    <TextView
        android:id="@+id/tvTodayReleasedTrackTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        tools:text="Lost corner"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTodayReleasedTrackArtist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Kenshi Yonezu" />

</LinearLayout>

