<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:padding="16dp"
    tools:context=".SongDetailActivity">

    <ImageView
        android:id="@+id/ivMusicFilter"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_filter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivDetailMusicCollapse"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_arrow_down"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/ivDetailMusicTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        tools:text="Pop Song"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivMusicFilter" />

    <TextView
        android:id="@+id/ivDetailMusicSinger"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        tools:text="Kenshi Yonezu"
        android:textColor="@color/black"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="@id/ivDetailMusicTitle"
        app:layout_constraintStart_toStartOf="@id/ivDetailMusicTitle"
        app:layout_constraintTop_toBottomOf="@id/ivDetailMusicTitle" />

    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="8dp"
        android:src="@drawable/ic_arrow_right"
        app:layout_constraintBottom_toBottomOf="@id/ivDetailMusicSinger"
        app:layout_constraintStart_toEndOf="@id/ivDetailMusicSinger"
        app:layout_constraintTop_toTopOf="@id/ivDetailMusicSinger" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvMusicAlbum"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivDetailMusicSinger">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/img_album_today_released_1" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvLyricsOne"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="가사 1"
        android:textSize="20sp"
        android:textColor="@color/black"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/cvMusicAlbum"
        app:layout_constraintStart_toStartOf="@id/cvMusicAlbum"
        app:layout_constraintEnd_toEndOf="@id/cvMusicAlbum"/>

    <TextView
        android:id="@+id/tvLyricsTwo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="가사 2"
        android:textSize="20sp"
        android:textColor="@color/black"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvLyricsOne"
        app:layout_constraintStart_toStartOf="@id/tvLyricsOne"
        app:layout_constraintEnd_toEndOf="@id/tvLyricsOne"/>

    <ImageView
        android:id="@+id/ivMusicHeart"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="40dp"
        android:src="@drawable/ic_heart"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintTop_toBottomOf="@id/tvLyricsTwo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/ivMusicBan"/>

    <ImageView
        android:id="@+id/ivMusicBan"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_ban"
        app:layout_constraintTop_toTopOf="@id/ivMusicHeart"
        app:layout_constraintBottom_toBottomOf="@id/ivMusicHeart"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivMusicHeart"/>

    <SeekBar
        android:id="@+id/seekbarDetailMusic"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:thumb="@drawable/custom_seekbar_thumb"
        android:progressTint="@color/seekbar_progress_color"
        android:thumbOffset="0dp"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivMusicHeart"/>

    <TextView
        android:id="@+id/tvSongTimeStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="@id/seekbarDetailMusic"
        app:layout_constraintTop_toBottomOf="@id/seekbarDetailMusic"
        android:text="00:00"/>

    <TextView
        android:id="@+id/tvSongTimeEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:layout_constraintEnd_toEndOf="@id/seekbarDetailMusic"
        app:layout_constraintTop_toBottomOf="@id/seekbarDetailMusic"
        tools:text="03:27"/>


    <ImageView
        android:id="@+id/ivMusicRepeat"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_repeat_all_inactive"
        android:layout_marginStart="20dp"
        app:layout_constraintVertical_bias="0.4"
        app:layout_constraintTop_toBottomOf="@id/tvSongTimeStart"
        app:layout_constraintBottom_toTopOf="@id/ivInstagram"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageView
        android:id="@+id/ivMusicPlayPrevious"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_play_previous"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toEndOf="@id/ivMusicRepeat"
        app:layout_constraintTop_toTopOf="@id/ivMusicRepeat"
        app:layout_constraintBottom_toBottomOf="@id/ivMusicRepeat"
        app:layout_constraintEnd_toStartOf="@id/ivMusicPlay"/>

    <ImageView
        android:id="@+id/ivMusicPlay"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_play_filled"
        app:layout_constraintStart_toEndOf="@id/ivMusicPlayPrevious"
        app:layout_constraintTop_toTopOf="@id/ivMusicPlayPrevious"
        app:layout_constraintBottom_toBottomOf="@id/ivMusicPlayPrevious"
        app:layout_constraintEnd_toStartOf="@id/ivMusicPlayNext"/>

    <ImageView
        android:id="@+id/ivMusicPlayNext"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_play_next"
        app:layout_constraintStart_toEndOf="@id/ivMusicPlay"
        app:layout_constraintTop_toTopOf="@id/ivMusicPlay"
        app:layout_constraintBottom_toBottomOf="@id/ivMusicPlay"
        app:layout_constraintEnd_toStartOf="@id/ivMusicShuffle"/>

    <ImageView
        android:id="@+id/ivMusicShuffle"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_shuffle"
        android:layout_marginEnd="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/ivMusicPlayNext"/>

    <ImageView
        android:id="@+id/ivInstagram"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_instagram"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/mbSimilarSong"
        app:layout_constraintBottom_toBottomOf="@id/mbSimilarSong"/>

    <ImageView
        android:id="@+id/ivMusicOption"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_option"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/mbSimilarSong"
        app:layout_constraintBottom_toBottomOf="@id/mbSimilarSong"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/mbSimilarSong"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="유사곡"
        android:textColor="@color/black"
        android:minWidth="0dp"
        app:cornerRadius="30dp"
        app:strokeColor="#CECECE"
        app:strokeWidth="2dp"
        app:layout_constraintStart_toEndOf="@id/ivInstagram"
        app:layout_constraintEnd_toStartOf="@id/ivMusicOption"
        app:layout_constraintBottom_toBottomOf="parent"/>




</androidx.constraintlayout.widget.ConstraintLayout>